{
  "name": "the-tuul",
  "version": "0.15.0",
  "description": "Create a decent karaoke video from any song in about 10 minutes.",
  "main": "index.ts",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "dev": "vite --host --config vite.config.dev.ts",
    "build": "vite build --mode production --config vite.config.prod.ts",
    "build-dev": "vite build --config vite.config.dev.ts",
    "watch": "vite build --config vite.config.dev.ts --watch --host",
    "version": "(cd api/ && poetry version $npm_package_version) && git add pyproject.toml"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/incidentist/karaoke_video_tools.git"
  },
  "keywords": [
    "karaoke"
  ],
  "author": "Dan Kurtz <andfurthermore@gmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/incidentist/karaoke_video_tools/issues"
  },
  "homepage": "https://github.com/incidentist/karaoke_video_tools#readme",
  "dependencies": {
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@fortawesome/fontawesome-free": "^6.7.2",
    "@fortawesome/fontawesome-svg-core": "^6.7.2",
    "@fortawesome/free-brands-svg-icons": "^6.7.2",
    "@fortawesome/free-regular-svg-icons": "^6.7.2",
    "@fortawesome/free-solid-svg-icons": "^6.7.2",
    "@fortawesome/vue-fontawesome": "^3.0.8",
    "audiobuffer-to-wav": "^1.0.0",
    "buefy": "npm:@ntohq/buefy-next@^0.2.0",
    "bulma": "^0.9.4",
    "jszip": "^3.10.1",
    "libass-wasm": "^4.1.0",
    "lodash-es": "^4.17.21",
    "pinia": "^3.0.2",
    "vue": "^3.5.13",
    "wavesurfer.js": "^7.8.2"
  },
  "devDependencies": {
    "@ffmpeg/types": "^0.12.4",
    "@playwright/test": "^1.51.1",
    "@types/jsmediatags": "^3.9.6",
    "@types/lodash": "^4.14.195",
    "@vitejs/plugin-vue": "^5.2.3",
    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^17.4.0",
    "playwright": "^1.25.0",
    "sass-embedded": "^1.86.0",
    "typescript": "^5.1.3",
    "vite": "^6.2.1",
    "vitest": "^3.0.8"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.39.0"
  }
}
